# PostgreSQL Configuration
# Used if not overridden by environment variables

DB_HOST=localhost
DB_PORT=5432
DB_NAME=NJ
DB_USER=postgres
DB_PASSWORD=admin

# ── GCP Credentials ──────────────────────────────────────────────────────────
#
# The code tries these in order:
#
#  1. GCP_SERVICE_ACCOUNT_B64   ← base64-encoded JSON  (use on AWS / Cloud Run)
#  2. GCP_SERVICE_ACCOUNT_JSON  ← path to JSON file    (use on GCP VMs / servers)
#  3. seismic-*.json            ← auto-detected in project root (dev only)
#
# ── For LOCAL development ─────────────────────────────────────────────────────
#  Place seismic-helper-364013-da1f4f449e3b.json in the dataMigrationJob/ folder.
#  No env var needed — it's auto-detected by name.
#
# ── For AWS (EC2, ECS, Lambda, Elastic Beanstalk) ────────────────────────────
#  Generate base64 from the JSON key file:
#    cat seismic-helper-364013-da1f4f449e3b.json | base64 | tr -d '\n'
#  Paste the output as the value below (or store in AWS Secrets Manager / SSM):
#
# GCP_SERVICE_ACCOUNT_B64=<paste base64 string here>
#
# ── For GCP (Cloud Run, GCE, App Engine) ─────────────────────────────────────
#  Option A — point to the JSON file:
# GCP_SERVICE_ACCOUNT_JSON=/secrets/seismic-helper-364013-da1f4f449e3b.json
#
#  Option B — same base64 approach also works on GCP:
# GCP_SERVICE_ACCOUNT_B64=<paste base64 string here>
#
# Required IAM roles on the service account:
#   roles/bigquery.dataViewer   (read table data)
#   roles/bigquery.jobUser      (run queries)
# ─────────────────────────────────────────────────────────────────────────────

# API Authentication (required when running api.py)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SYNC_API_KEY=your-secret-api-key-here

# API Server
PORT=8080
ENV=development
