# ============================================================================
# PostgreSQL Configuration
# ============================================================================
# Target database connection details
DB_HOST=localhost
DB_PORT=5432
DB_NAME=NJ
DB_USER=postgres
DB_PASSWORD=admin


# ============================================================================
# GCP Configuration
# ============================================================================
# GCP Project ID (auto-detected from credentials if not set)
# GCP_PROJECT_ID=seismic-helper-364013

# The code tries credentials in order:
#  1. GCP_SERVICE_ACCOUNT_B64   ← base64-encoded JSON  (AWS/Cloud Run — RECOMMENDED)
#  2. GCP_SERVICE_ACCOUNT_JSON  ← path to JSON file    (GCP VMs/servers with mounted secrets)
#  3. seismic-*.json            ← auto-detected in project root (development — DEPRECATED)


# ── For LOCAL development ─────────────────────────────────────────────────────
# Place seismic-helper-364013-da1f4f449e3b.json in the dataMigrationJob/ folder.
# No environment variables needed — it will be auto-detected.
# (Only recommended for development — WARNING: Do not commit the JSON file!)


# ── For AWS (EC2, ECS, Lambda, Elastic Beanstalk) ────────────────────────────
# Generate base64 from your service account JSON:
#   cat seismic-helper-364013-da1f4f449e3b.json | base64 | tr -d '\n'
#
# Then set:
# GCP_SERVICE_ACCOUNT_B64=<paste-base64-string-here>


# ── For GCP (Cloud Run, GCE, App Engine) ─────────────────────────────────────
# Option A — point to mounted secret file:
# GCP_SERVICE_ACCOUNT_JSON=/secrets/seismic-helper-364013-da1f4f449e3b.json
#
# Option B — same base64 approach:
# GCP_SERVICE_ACCOUNT_B64=<paste-base64-string-here>
#
# Required IAM roles on service account:
#   roles/bigquery.dataViewer   (read table data)
#   roles/bigquery.jobUser      (run queries)
#   roles/bigquery.metadataViewer (inspect table schema)


# ============================================================================
# BigQuery Configuration
# ============================================================================
# BigQuery project (defaults to GCP_PROJECT_ID)
# BQ_PROJECT=seismic-helper-364013

# Default dataset for table references
# BQ_DATASET=raw_data


# ============================================================================
# Migration Job Settings
# ============================================================================
# Number of parallel workers for concurrent table migrations
PARALLEL_WORKERS=1

# Batch size for data transfer (rows per batch)
BATCH_SIZE=1000

# Enable post-migration validation (compares row counts)
ENABLE_VALIDATION=True

# Enable automatic schema drift detection and DDL application
ENABLE_SCHEMA_DRIFT=True


# ============================================================================
# API Configuration
# ============================================================================
# Environment stage (development, staging, production)
ENV=development

# API server port
PORT=8080

# API authentication key (required for /sync endpoint)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SYNC_API_KEY=your-secret-api-key-here

